// Add bar — link-icon-prefixed input + primary "Add" button + theme-toggle
// + gear (UC 09 reserved). Port of design/project/app.jsx ~lines 187-235.
//
// URL input: low-level `TextInput` with `single-line: false; wrap: no-wrap;`
// — this preserves the multi-URL paste UX (`\n`-separated, split by
// `model::split_pasted_urls`) while keeping the visible strip one line tall.
// Placeholder is overlaid as a separate `Text` element because `TextInput`
// lacks a `placeholder-text` property. `std-widgets::TextEdit` was tried
// previously and avoided because its multi-line scroll-view chrome clipped
// typed text down to a thin sliver at the 30-px input height (UC 29).
// Top alignment is chosen over center per UC 07's `align-items: stretch`
// baseline anchor and because, on a multi-URL paste, the alternative is a
// two-sided clip — top-anchored, the first URL stays fully legible and the
// overflow is one-sided (subsequent URLs clip off the bottom).

import { DesignTokens } from "design/tokens.slint";
import { Button, Icon, Toggle } from "design/components.slint";
import { Icons } from "icons.slint";

export component AddBar inherits Rectangle {
    in-out property <string> value <=> ti.text;
    // UC 19: per-URL "Audio only" toggle. Defaults to false (audio + video)
    // per AC #1; AC #6 — resets to false whenever the URL field is cleared.
    in-out property <bool> audio-only-on: false;
    // UC 29: mirrors the placeholder Text's `visible:` predicate. Exposed
    // so callers (and tests) can observe placeholder-vs-text state without
    // reaching into the internal `ti`.
    out property <bool> placeholder-visible: ti.text == "";

    callback add-clicked();
    callback toggle-theme-clicked();
    callback gear-clicked();
    // UC 19: informational — emitted when the toggle flips so a parent can
    // observe state changes if needed. Internal state is held by `audio-only-on`.
    callback audio-only-toggled(bool);

    // UC 19 / AC #6: defense-in-depth reset. When the URL field is cleared
    // (e.g. parent zeroes `value` after add-clicked), drop the toggle back
    // to "Audio + video". Idempotent: setting the same value is a no-op.
    changed value => {
        if (self.value == "") {
            self.audio-only-on = false;
        }
    }

    background: DesignTokens.surface;
    border-color: DesignTokens.border;
    border-width: 0;
    height: 54px;

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        padding-top: 12px;
        padding-bottom: 12px;
        spacing: 8px;
        alignment: stretch;

        // Input region — link icon + multi-line-capable TextInput overlaid
        // with a separate placeholder Text. (UC 29 fix.)
        Rectangle {
            horizontal-stretch: 1;
            border-radius: DesignTokens.radius;
            border-width: 1px;
            border-color: DesignTokens.border-strong;
            background: DesignTokens.surface;

            Icon {
                x: 10px;
                y: (parent.height - self.height) / 2;
                source: Icons.link;
                size: "sm";
                tint: DesignTokens.text-3;
            }

            // Placeholder overlay. MUST appear before `ti` so TextInput
            // renders on top and receives clicks. A future reformat that
            // reorders these siblings would silently break click hit-testing
            // and placeholder visibility. (UC 29.)
            Text {
                x: 30px;
                y: 0;
                width: parent.width - 30px;
                height: parent.height;
                text: "Paste a video or playlist URL — multiple lines supported";
                color: DesignTokens.text-3;
                font-family: DesignTokens.font-ui-family;
                font-size: 13px;
                vertical-alignment: top;
                visible: ti.text == "";
            }

            ti := TextInput {
                x: 30px;
                y: 0;
                width: parent.width - 30px;
                height: parent.height;
                color: DesignTokens.text;
                font-family: DesignTokens.font-ui-family;
                font-size: 13px;
                // Keep `\n` in the bound `value` so multi-URL paste keeps
                // working via `model::split_pasted_urls`. UC 29.
                single-line: false;
                // The visible strip is one line tall; we do not want the
                // pasted multi-URL blob to soft-wrap the first URL across
                // multiple visual rows. UC 29.
                wrap: no-wrap;
                // Top-anchored: avoids the two-sided clip on multi-line
                // paste. First line stays fully legible at the top edge.
                // UC 29.
                vertical-alignment: top;
                selection-background-color: DesignTokens.accent-soft;
                selection-foreground-color: DesignTokens.accent-text;
            }
        }

        // UC 19: per-URL "Audio only" toggle. Sits between the URL field
        // and the Add button so it reads as "this applies to what I'm about
        // to add". Mono-caption label matches the rest of the captioned
        // controls in the surface (~11 px, mono).
        HorizontalLayout {
            spacing: 6px;
            alignment: center;
            horizontal-stretch: 0;

            Text {
                text: "Audio only";
                color: DesignTokens.text-3;
                font-family: DesignTokens.font-mono-family;
                font-size: 11px;
                vertical-alignment: center;
            }

            Toggle {
                on: root.audio-only-on;
                toggled(v) => {
                    root.audio-only-on = v;
                    root.audio-only-toggled(v);
                }
            }
        }

        // Add button (primary, with plus icon).
        Button {
            text: "Add";
            variant: "primary";
            icon: Icons.plus;
            clicked => { root.add-clicked(); }
        }

        // Theme toggle (icon button).
        Button {
            modifier: "icon";
            icon: DesignTokens.dark-mode ? Icons.sun : Icons.moon;
            clicked => { root.toggle-theme-clicked(); }
        }

        // Hamburger menu — toggles the settings panel. (Was Icons.gear, but
        // gear.svg is visually almost identical to sun.svg / moon.svg, which
        // made the settings button collide with the theme toggle next to it.)
        Button {
            modifier: "icon";
            icon: Icons.menu;
            clicked => { root.gear-clicked(); }
        }
    }
}
