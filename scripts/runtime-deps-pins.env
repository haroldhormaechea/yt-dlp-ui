# runtime-deps-pins.env — pinned versions and SHA256 digests for the
# bundled native binaries fetched at release time.
#
# Format: shell-style KEY=VALUE, one per line. Sourced verbatim by Bash
# (`source scripts/runtime-deps-pins.env`); parsed line-by-line by
# PowerShell. No quoting around values; no spaces around `=`.
#
# Owned by UC 17 (ffmpeg) and the existing UC 06 supply-chain posture.
# Bumping any pin here is a manual PR per scripts/README.md § Bump procedure.
#
# Why two FFmpeg version axes?
#   - Linux/Windows fetch a prebuilt LGPL-only static binary from
#     BtbN/FFmpeg-Builds, addressed by an autobuild release tag plus the
#     in-tag stable-release filename pattern (`ffmpeg-n7.1.4-...`).
#   - macOS builds FFmpeg from source on the GHA macOS runners (no LGPL-
#     only mainstream macOS build exists; evermeet ships x86_64 only).
#     The source-tarball pin lives separately because the upstream
#     ffmpeg.org tarball cadence is independent of the BtbN republish
#     cadence.

# === Linux / Windows: BtbN/FFmpeg-Builds (LGPL-only static, n7.1.4) ===
FFMPEG_VERSION=autobuild-2026-05-06-13-32
FFMPEG_RELEASE_TAG=n7.1.4
FFMPEG_SHA256_LINUX64=ee049f52e87e83e07006b16ae60af26c7afe01489015114b14e330eb121034eb
FFMPEG_SHA256_LINUXARM64=a5b516557508278089607df00d1a024df5a8476ba1e2e81f4ecabf50273f1485
FFMPEG_SHA256_WIN64=223ffbe78a541e43ff472808ecc20c3ae961e4b442fff8ba6fed4c4503b84333

# === macOS: built from upstream FFmpeg source on GHA runners ===
FFMPEG_VERSION_SOURCE=7.1
FFMPEG_TARBALL_SHA256_SOURCE=40973d44970dbc83ef302b0609f2e74982be2d85916dd2ee7472d30678a7abe6

# === yt-dlp + deno (UC 18: pinned for the About dialog at build time) ===
#
# DUPLICATED in .github/workflows/{release,package-deb-rpm,package-dmg,package-nsis}.yml
# until a follow-up consolidation use case lands. Bumping requires updating BOTH
# this file AND the four workflow YAMLs. Drift between them will be visible:
# the workflows decide which binaries are bundled into the installer; this file
# decides which version strings are baked into the About dialog. They MUST match.
YT_DLP_VERSION=2026.03.17
DENO_VERSION=1.47.2
